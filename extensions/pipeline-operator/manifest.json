{
  "manifest_version": 3,
  "name": "Pipeline Operator",
  "version": "1.1.0",
  "description": "Pre-fills Greenhouse and Ashby application forms for operator-assisted submissions.",
  "permissions": ["scripting", "tabs", "storage", "debugger"],
  "host_permissions": [
    "https://job-boards.greenhouse.io/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.digitaloceanspaces.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://job-boards.greenhouse.io/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobs.ashbyhq.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pipeline Operator"
  }
}
