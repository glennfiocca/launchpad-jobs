// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ReferralStatus {
  PENDING
  CONVERTED
  EXPIRED
  FLAGGED
  REVOKED
}

enum CreditTransactionType {
  REFERRAL_BONUS
  ADMIN_GRANT
  ADMIN_DEDUCTION
  REFERRAL_REVOKE
}

enum AtsProvider {
  GREENHOUSE
  ASHBY
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Bumped on auth-invalidating events (email change, future: password change,
  // forced sign-out). NextAuth jwt callback compares this to the JWT-embedded
  // version and treats mismatched tokens as expired.
  tokenVersion Int @default(0)

  // CCPA/CPRA universal opt-out. Set to true when an authenticated user's
  // request carries `Sec-GPC: 1` (Global Privacy Control). One-way in v1 —
  // never automatically reverted; the user must explicitly opt back in via
  // a future UI. Honored as the legal "Do Not Sell or Share" signal.
  gpcOptOut Boolean @default(false)

  role      Role     @default(USER)

  // Billing
  stripeCustomerId   String?            @unique
  subscriptionStatus SubscriptionStatus @default(FREE)

  // Free-tier rolling 24h credit window
  creditWindowStart DateTime @default(now())
  creditsUsed       Int      @default(0)

  // Referral system
  referralCode        String?   @unique
  normalizedEmail     String?   @unique
  signupIpAddress     String?
  referralCredits     Int       @default(0)
  referralsSent       Referral[] @relation("ReferralsSent")
  referralReceived    Referral?  @relation("ReferralReceived")
  creditTransactions  CreditTransaction[]
  creditActorLogs     CreditTransaction[] @relation("CreditActor")

  accounts               Account[]
  sessions               Session[]
  profile                UserProfile?
  applications           Application[]
  subscription           Subscription?
  feedback               Feedback[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  claimedApplications    Application[]           @relation("ApplicationClaims")
  auditLogs              ApplicationAuditLog[]   @relation("AuditLogActor")
  savedJobs              SavedJob[]
  jobReports             JobReport[]
  emailChangeRequests    EmailChangeRequest[]
  loginEvents            LoginEvent[]
  contactMessages        ContactMessage[]

  @@index([deletedAt])
}

// Public contact-form submissions from /contact. Persisted before the email
// dispatch so messages are never lost if Resend is unavailable — admins can
// sweep WHERE deliveredAt IS NULL to retry. Auth-optional: anyone can submit.
// FK uses SetNull (not Cascade) so privacy-related submissions outlive an
// account deletion for legal/audit purposes.
model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  // App-validated enum: general | privacy | account | bug | other
  category    String
  pageUrl     String?
  message     String   @db.Text
  ipAddress   String?
  userAgent   String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([category])
  @@index([userId])
}

// Append-only sign-in audit trail. One row per successful authentication.
// ipAddress / userAgent are nullable because the NextAuth events.signIn
// hook doesn't expose request context — they're populated only if a future
// middleware path captures and forwards them.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  provider  String?

  @@index([userId, createdAt(sort: Desc)])
}

// Pending email-change requests. Each request has a hashed token sent to the
// proposed new address; consumption atomically updates User.email and bumps
// User.tokenVersion to invalidate all outstanding JWTs.
model EmailChangeRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newEmail    String
  tokenHash   String   @unique // sha256(token)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  ipAddress   String?

  @@index([userId])
  @@index([expiresAt])
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSubscriptionId   String   @unique
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime
  cancelAtPeriodEnd      Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal
  firstName          String
  lastName           String
  preferredFirstName String?
  email       String
  phone       String?
  location    String?

  // Professional links
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?

  // Resume — stored in DB (bytes), migrates to DO Spaces (url) in production
  resumeData     Bytes?
  resumeUrl      String?   // set when using DO Spaces
  resumeFileName String?
  resumeMimeType String?

  // Headline & bio
  headline String?
  summary  String? @db.Text

  // Current/desired role
  currentTitle    String?
  currentCompany  String?
  yearsExperience Int?

  // Salary
  desiredSalaryMin Int?
  desiredSalaryMax Int?

  // Work preferences
  openToRemote Boolean @default(true)
  openToHybrid Boolean @default(true)
  openToOnsite Boolean @default(false)

  // Education
  highestDegree  String?
  fieldOfStudy   String?
  university     String?   // legacy free-text (soft-deprecated; use universityId)
  graduationYear Int?

  // University FK (structured)
  universityId String?
  university_  University? @relation(fields: [universityId], references: [id])

  // Structured address (Google Places)
  locationPlaceId    String?
  locationFormatted  String?
  locationStreet     String?
  locationCity       String?
  locationState      String?
  locationPostalCode String?
  locationLat        Float?
  locationLng        Float?

  // Eligibility
  workAuthorization   String? // US_CITIZEN, GREEN_CARD, VISA, OTHER
  requiresSponsorship Boolean @default(false)

  // Custom free-form answers stored as JSON
  // { "questionKey": "answer" }
  customAnswers Json?

  isComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model University {
  id       String        @id @default(cuid())
  ipedId   String        @unique
  name     String
  city     String?
  state    String?       // 2-letter abbreviation
  profiles UserProfile[]

  @@index([name])
}

model Company {
  id       String      @id @default(cuid())
  name     String
  slug     String      // Greenhouse board token (unique per provider)
  provider AtsProvider @default(GREENHOUSE)

  logoUrl  String?
  website  String?
  industry String?
  size     String?
  about    String? @db.Text

  /// CSS selector override for the apply trigger button on self-hoster
  /// careers pages (Track A.2 of HARDENING_PLAN.md). When set, the Ashby
  /// Playwright strategy uses this selector instead of the generic fallback
  /// chain. Opt-in only — leave null to use generic selectors.
  applySelector String?

  jobs Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, slug])
}

model Job {
  id         String      @id @default(cuid())
  /// External listing ref (e.g. PL + hash) for URLs and search; internal `id` stays the FK.
  publicJobId String     @unique
  externalId String      // Greenhouse job ID (numeric string)
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id])
  provider   AtsProvider @default(GREENHOUSE)

  title          String
  location       String?
  department     String?
  employmentType String?
  remote         Boolean @default(false)

  // Greenhouse identifiers
  boardToken  String
  absoluteUrl String? // Human-facing "View original listing" deeplink
  /// Machine-facing apply URL used by the Playwright submission path + the
  /// JWT-snapshot manualApplyUrl. For Ashby self-hosters this equals
  /// absoluteUrl (the apply form is on the listing page). For hosted
  /// boards it differs (e.g. /jobs/{id}/application). Nullable — when
  /// null, the apply caller derives a canonical fallback per provider.
  applyUrl    String?

  // Full job content (HTML from Greenhouse)
  content String? @db.Text

  // Parsed metadata
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?

  // Location classification (see src/lib/location-classifier).
  // `isUSEligible` is the sole bit the listing API consumes; the other two
  // fields are admin/debug surfaces. Default true so freshly-inserted rows
  // are visible until the classifier (run during sync) refines them.
  countryCode      String?
  locationCategory String?
  isUSEligible     Boolean @default(true)

  // Questions required for application (JSON array)
  // [{ "id": "123", "label": "...", "required": true, "type": "text" }]
  applicationQuestions Json?

  /// Full-text search vector. Maintained by DB trigger — do not write from application code.
  searchVector Unsupported("tsvector")?

  isActive     Boolean   @default(true)
  postedAt     DateTime?
  /// JobPosting validity window for Google structured data. Refreshed on every
  /// successful upstream sync; lapses naturally when the source ATS stops
  /// listing a job. See src/config/seo.ts (VALIDITY_WINDOW_DAYS).
  validThrough DateTime?

  applications  Application[]
  notifications Notification[]
  savedJobs     SavedJob[]
  jobReports    JobReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, externalId, boardToken])
  @@index([companyId])
  @@index([isActive])
  @@index([remote])
  @@index([department])
  @@index([postedAt])
  @@index([validThrough])
  @@index([isUSEligible])
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  PHONE_SCREEN
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
  LISTING_REMOVED
}

model Application {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id])

  status ApplicationStatus @default(APPLIED)

  // Greenhouse application ID (returned after successful submission)
  externalApplicationId String?

  // Tracking email address for this application (for Resend inbound)
  trackingEmail String? @unique

  // Notes the user adds
  userNotes String? @db.Text

  // Error message from the last failed auto-submit attempt
  submissionError String? @db.Text

  // Tracks async Playwright submission lifecycle: PENDING | SUBMITTED | FAILED | AWAITING_OPERATOR
  submissionStatus  String @default("PENDING")

  // Immutable snapshot of apply-time data written when AWAITING_OPERATOR
  applicationSnapshot Json?

  // Operator claim fields
  claimedByUserId String?
  claimedBy       User?     @relation("ApplicationClaims", fields: [claimedByUserId], references: [id])
  claimedAt       DateTime?

  // Which path completed submission: AUTOMATED | ASSISTED
  dispatchMode String?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emails        ApplicationEmail[]
  statusHistory ApplicationStatusHistory[]
  notifications Notification[]
  auditLogs     ApplicationAuditLog[]
  documents     ApplicationDocument[]

  @@unique([userId, jobId])
  @@index([userId])
  @@index([status])
  @@index([externalApplicationId])
  @@index([appliedAt])
  @@index([submissionStatus])
  @@index([claimedByUserId])
}

// First-class artifacts attached to an application — currently used for
// operator-queue Q&A summary PDFs. Kept narrow to keep storage minimal:
// the actual bytes live in DO Spaces (private), this row points at them.
model ApplicationDocument {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Document classification — one document per (applicationId, kind) for idempotency.
  // Known kinds: OPERATOR_SUMMARY (Q&A PDF for operator queue).
  kind String

  fileName  String
  mimeType  String
  spacesKey String  @unique
  sizeBytes Int

  // Optional human-friendly title (e.g. "Q&A Summary — Acme / Senior Engineer")
  title String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([applicationId, kind])
  @@index([applicationId])
  @@index([kind])
}

model ApplicationEmail {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  messageId String? @unique // Email message ID for deduplication
  from      String
  to        String
  subject   String
  body      String  @db.Text
  htmlBody  String? @db.Text

  // AI-determined classification
  aiClassification ApplicationStatus?
  aiConfidence     Float?
  aiReasoning      String? @db.Text

  direction String @default("inbound") // inbound | outbound

  receivedAt DateTime
  createdAt  DateTime @default(now())

  @@index([applicationId])
}

model ApplicationStatusHistory {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  fromStatus  ApplicationStatus?
  toStatus    ApplicationStatus
  reason      String?
  triggeredBy String @default("system") // user | ai | system

  createdAt DateTime @default(now())

  @@index([applicationId])
}

model CompanyBoard {
  id         String      @id @default(cuid())
  name       String
  boardToken String
  provider   AtsProvider @default(GREENHOUSE)
  logoUrl    String?
  website    String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([provider, boardToken])
}

enum FeedbackType {
  BUG
  FEATURE
  PRAISE
  OTHER
}

model Feedback {
  id        String       @id @default(cuid())
  type      FeedbackType
  rating    Int?
  message   String       @db.Text
  pageUrl   String
  userId    String?
  userEmail String?
  userAgent String?
  createdAt DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
  @@index([userId])
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL_FAILURE
  FAILURE
}

enum SyncBoardStatus {
  SUCCESS
  FAILURE
  SKIPPED
}

model SyncLog {
  id           String     @id @default(cuid())
  triggeredBy  String     // "cron" | "admin:<email>" | "api"
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  status       SyncStatus @default(RUNNING)
  totalBoards  Int        @default(0)
  boardsSynced Int        @default(0)
  boardsFailed Int        @default(0)
  totalAdded   Int        @default(0)
  totalUpdated Int        @default(0)
  totalDeactivated         Int @default(0)
  totalApplicationsUpdated Int @default(0)
  durationMs   Int?
  errorSummary String?    @db.Text

  boardResults SyncBoardResult[]

  @@index([startedAt])
  @@index([status])
}

model SyncBoardResult {
  id          String          @id @default(cuid())
  syncLogId   String
  syncLog     SyncLog         @relation(fields: [syncLogId], references: [id], onDelete: Cascade)
  boardToken  String
  boardName   String
  status      SyncBoardStatus
  added       Int             @default(0)
  updated     Int             @default(0)
  deactivated Int             @default(0)
  applicationsUpdated Int     @default(0)
  errors      String[]        @default([])
  startedAt   DateTime
  completedAt DateTime?
  durationMs  Int?

  @@index([syncLogId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  APPLIED
  APPLICATION_STATUS_CHANGE
  APPLICATION_OFFER
  APPLICATION_INTERVIEW
  APPLICATION_REJECTED
  EMAIL_RECEIVED
  LISTING_REMOVED
  APPLY_FAILED
  TEAM_MESSAGE
  SYSTEM
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum EmailFrequency {
  INSTANT
  DAILY
  NEVER
}

model Notification {
  id       String               @id @default(cuid())
  userId   String
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     NotificationType
  priority NotificationPriority @default(NORMAL)

  // Pre-rendered content for fast reads
  title    String
  body     String?  @db.Text
  ctaUrl   String?
  ctaLabel String?

  // Typed payload (validated by Zod at write time)
  data Json?

  // Optional FK links — cascade keeps history clean
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  jobId         String?
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)

  isRead Boolean   @default(false)
  readAt DateTime?

  emailSent   Boolean   @default(false)
  emailSentAt DateTime?

  // Prevents duplicate notifications for the same event
  dedupeKey String? @unique

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([applicationId])
  @@index([createdAt])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailFrequency EmailFrequency @default(INSTANT)

  // Per-type email toggles (in-app is always on)
  emailOnOffer          Boolean @default(true)
  emailOnInterview      Boolean @default(true)
  emailOnStatusChange   Boolean @default(true)
  emailOnEmailReceived  Boolean @default(false) // too chatty by default
  emailOnListingRemoved Boolean @default(true)
  emailOnTeamMessage    Boolean @default(true)
  emailOnSystem         Boolean @default(true)
  emailOnApplyFailed    Boolean @default(true)

  // Throttle digest emails
  lastDigestSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Operator Queue Audit ─────────────────────────────────────────────────────

model ApplicationAuditLog {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actorUserId   String?
  actor         User?       @relation("AuditLogActor", fields: [actorUserId], references: [id])

  // CLAIM | RELEASE | FILL_PACKAGE_ISSUED | OPERATOR_SUBMITTED | OPERATOR_FAILED | PLAYWRIGHT_RESULT
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([applicationId])
  @@index([actorUserId])
}

// ─── Referral System ─────────────────────────────────────────────────────────

model Referral {
  id                   String         @id @default(cuid())
  referrerId           String
  referrer             User           @relation("ReferralsSent", fields: [referrerId], references: [id])
  refereeId            String?        @unique
  referee              User?          @relation("ReferralReceived", fields: [refereeId], references: [id])
  referralCode         String
  status               ReferralStatus @default(PENDING)
  refereeIpAddress     String?
  referrerIpAddress    String?
  ipFlagged            Boolean        @default(false)
  firstApplicationAt   DateTime?
  creditTransactionId  String?        @unique
  creditTransaction    CreditTransaction? @relation(fields: [creditTransactionId], references: [id])
  expiresAt            DateTime
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([referrerId])
  @@index([referralCode])
  @@index([status])
  @@index([expiresAt])
}

model CreditTransaction {
  id           String                @id @default(cuid())
  userId       String
  user         User                  @relation(fields: [userId], references: [id])
  type         CreditTransactionType
  amount       Int
  referralId   String?
  actorUserId  String?
  actor        User?                 @relation("CreditActor", fields: [actorUserId], references: [id])
  note         String?
  balanceAfter Int
  createdAt    DateTime              @default(now())
  referral     Referral?

  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
}

// ─── Saved Jobs ───────────────────────────────────────────────────────────────

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── Job Reports ──────────────────────────────────────────────────────────────

enum ReportCategory {
  SPAM
  INACCURATE
  OFFENSIVE
  BROKEN_LINK
  OTHER
}

enum ReportStatus {
  OPEN
  TRIAGED
  RESOLVED
  DISMISSED
}

model JobReport {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId      String?
  job        Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  category   ReportCategory
  status     ReportStatus   @default(OPEN)
  message    String?        @db.VarChar(1000)
  resolvedAt DateTime?
  resolvedBy String?
  adminNote  String?        @db.Text
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([userId, jobId])
  @@index([status, createdAt(sort: Desc)])
  @@index([jobId])
  @@index([userId])
}
