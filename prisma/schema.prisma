// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role      Role     @default(USER)

  // Billing
  stripeCustomerId   String?            @unique
  subscriptionStatus SubscriptionStatus @default(FREE)

  // Free-tier rolling 24h credit window
  creditWindowStart DateTime @default(now())
  creditsUsed       Int      @default(0)

  accounts               Account[]
  sessions               Session[]
  profile                UserProfile?
  applications           Application[]
  subscription           Subscription?
  feedback               Feedback[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  claimedApplications    Application[]           @relation("ApplicationClaims")
  auditLogs              ApplicationAuditLog[]   @relation("AuditLogActor")
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSubscriptionId   String   @unique
  stripePriceId          String
  stripeCurrentPeriodEnd DateTime
  cancelAtPeriodEnd      Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal
  firstName   String
  lastName    String
  email       String
  phone       String?
  location    String?

  // Professional links
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?

  // Resume — stored in DB (bytes), migrates to DO Spaces (url) in production
  resumeData     Bytes?
  resumeUrl      String?   // set when using DO Spaces
  resumeFileName String?
  resumeMimeType String?

  // Headline & bio
  headline String?
  summary  String? @db.Text

  // Current/desired role
  currentTitle    String?
  currentCompany  String?
  yearsExperience Int?

  // Salary
  desiredSalaryMin Int?
  desiredSalaryMax Int?

  // Work preferences
  openToRemote Boolean @default(true)
  openToHybrid Boolean @default(true)
  openToOnsite Boolean @default(false)

  // Education
  highestDegree  String?
  fieldOfStudy   String?
  university     String?   // legacy free-text (soft-deprecated; use universityId)
  graduationYear Int?

  // University FK (structured)
  universityId String?
  university_  University? @relation(fields: [universityId], references: [id])

  // Structured address (Google Places)
  locationPlaceId    String?
  locationFormatted  String?
  locationStreet     String?
  locationCity       String?
  locationState      String?
  locationPostalCode String?
  locationLat        Float?
  locationLng        Float?

  // Eligibility
  workAuthorization   String? // US_CITIZEN, GREEN_CARD, VISA, OTHER
  requiresSponsorship Boolean @default(false)

  // Voluntary identification (EEOC)
  voluntaryGender        String?
  voluntaryRace          String?
  voluntaryVeteranStatus String?
  voluntaryDisability    String?

  // Custom free-form answers stored as JSON
  // { "questionKey": "answer" }
  customAnswers Json?

  isComplete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model University {
  id       String        @id @default(cuid())
  ipedId   String        @unique
  name     String
  city     String?
  state    String?       // 2-letter abbreviation
  profiles UserProfile[]

  @@index([name])
}

model Company {
  id   String @id @default(cuid())
  name String
  slug String @unique // Greenhouse board token

  logoUrl  String?
  website  String?
  industry String?
  size     String?
  about    String? @db.Text

  jobs Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id         String  @id @default(cuid())
  /// External listing ref (e.g. PL + hash) for URLs and search; internal `id` stays the FK.
  publicJobId String  @unique
  externalId String  // Greenhouse job ID (numeric string)
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])

  title          String
  location       String?
  department     String?
  employmentType String?
  remote         Boolean @default(false)

  // Greenhouse identifiers
  boardToken  String
  absoluteUrl String? // Greenhouse job URL

  // Full job content (HTML from Greenhouse)
  content String? @db.Text

  // Parsed metadata
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String?

  // Questions required for application (JSON array)
  // [{ "id": "123", "label": "...", "required": true, "type": "text" }]
  applicationQuestions Json?

  /// Full-text search vector. Maintained by DB trigger — do not write from application code.
  searchVector Unsupported("tsvector")?

  isActive Boolean   @default(true)
  postedAt DateTime?

  applications  Application[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([externalId, boardToken])
  @@index([companyId])
  @@index([isActive])
  @@index([remote])
  @@index([department])
  @@index([postedAt])
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  PHONE_SCREEN
  INTERVIEWING
  OFFER
  REJECTED
  WITHDRAWN
  LISTING_REMOVED
}

model Application {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id])

  status ApplicationStatus @default(APPLIED)

  // Greenhouse application ID (returned after successful submission)
  externalApplicationId String?

  // Tracking email address for this application (for Resend inbound)
  trackingEmail String? @unique

  // Notes the user adds
  userNotes String? @db.Text

  // Error message from the last failed auto-submit attempt
  submissionError String? @db.Text

  // Tracks async Playwright submission lifecycle: PENDING | SUBMITTED | FAILED | AWAITING_OPERATOR
  submissionStatus  String @default("PENDING")

  // Immutable snapshot of apply-time data written when AWAITING_OPERATOR
  applicationSnapshot Json?

  // Operator claim fields
  claimedByUserId String?
  claimedBy       User?     @relation("ApplicationClaims", fields: [claimedByUserId], references: [id])
  claimedAt       DateTime?

  // Which path completed submission: AUTOMATED | ASSISTED
  dispatchMode String?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emails        ApplicationEmail[]
  statusHistory ApplicationStatusHistory[]
  notifications Notification[]
  auditLogs     ApplicationAuditLog[]

  @@unique([userId, jobId])
  @@index([userId])
  @@index([status])
  @@index([externalApplicationId])
  @@index([appliedAt])
  @@index([submissionStatus])
  @@index([claimedByUserId])
}

model ApplicationEmail {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  messageId String? @unique // Email message ID for deduplication
  from      String
  to        String
  subject   String
  body      String  @db.Text
  htmlBody  String? @db.Text

  // AI-determined classification
  aiClassification ApplicationStatus?
  aiConfidence     Float?
  aiReasoning      String? @db.Text

  direction String @default("inbound") // inbound | outbound

  receivedAt DateTime
  createdAt  DateTime @default(now())

  @@index([applicationId])
}

model ApplicationStatusHistory {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  fromStatus  ApplicationStatus?
  toStatus    ApplicationStatus
  reason      String?
  triggeredBy String @default("system") // user | ai | system

  createdAt DateTime @default(now())

  @@index([applicationId])
}

model CompanyBoard {
  id         String   @id @default(cuid())
  name       String
  boardToken String   @unique
  logoUrl    String?
  website    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum FeedbackType {
  BUG
  FEATURE
  PRAISE
  OTHER
}

model Feedback {
  id        String       @id @default(cuid())
  type      FeedbackType
  rating    Int?
  message   String       @db.Text
  pageUrl   String
  userId    String?
  userEmail String?
  userAgent String?
  createdAt DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
  @@index([userId])
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL_FAILURE
  FAILURE
}

enum SyncBoardStatus {
  SUCCESS
  FAILURE
  SKIPPED
}

model SyncLog {
  id           String     @id @default(cuid())
  triggeredBy  String     // "cron" | "admin:<email>" | "api"
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  status       SyncStatus @default(RUNNING)
  totalBoards  Int        @default(0)
  boardsSynced Int        @default(0)
  boardsFailed Int        @default(0)
  totalAdded   Int        @default(0)
  totalUpdated Int        @default(0)
  totalDeactivated         Int @default(0)
  totalApplicationsUpdated Int @default(0)
  durationMs   Int?
  errorSummary String?    @db.Text

  boardResults SyncBoardResult[]

  @@index([startedAt])
  @@index([status])
}

model SyncBoardResult {
  id          String          @id @default(cuid())
  syncLogId   String
  syncLog     SyncLog         @relation(fields: [syncLogId], references: [id], onDelete: Cascade)
  boardToken  String
  boardName   String
  status      SyncBoardStatus
  added       Int             @default(0)
  updated     Int             @default(0)
  deactivated Int             @default(0)
  applicationsUpdated Int     @default(0)
  errors      String[]        @default([])
  startedAt   DateTime
  completedAt DateTime?
  durationMs  Int?

  @@index([syncLogId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

enum NotificationType {
  APPLIED
  APPLICATION_STATUS_CHANGE
  APPLICATION_OFFER
  APPLICATION_INTERVIEW
  APPLICATION_REJECTED
  EMAIL_RECEIVED
  LISTING_REMOVED
  APPLY_FAILED
  TEAM_MESSAGE
  SYSTEM
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum EmailFrequency {
  INSTANT
  DAILY
  NEVER
}

model Notification {
  id       String               @id @default(cuid())
  userId   String
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     NotificationType
  priority NotificationPriority @default(NORMAL)

  // Pre-rendered content for fast reads
  title    String
  body     String?  @db.Text
  ctaUrl   String?
  ctaLabel String?

  // Typed payload (validated by Zod at write time)
  data Json?

  // Optional FK links — cascade keeps history clean
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  jobId         String?
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)

  isRead Boolean   @default(false)
  readAt DateTime?

  emailSent   Boolean   @default(false)
  emailSentAt DateTime?

  // Prevents duplicate notifications for the same event
  dedupeKey String? @unique

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([applicationId])
  @@index([createdAt])
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailFrequency EmailFrequency @default(INSTANT)

  // Per-type email toggles (in-app is always on)
  emailOnOffer          Boolean @default(true)
  emailOnInterview      Boolean @default(true)
  emailOnStatusChange   Boolean @default(true)
  emailOnEmailReceived  Boolean @default(false) // too chatty by default
  emailOnListingRemoved Boolean @default(true)
  emailOnTeamMessage    Boolean @default(true)
  emailOnSystem         Boolean @default(true)
  emailOnApplyFailed    Boolean @default(true)

  // Throttle digest emails
  lastDigestSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Operator Queue Audit ─────────────────────────────────────────────────────

model ApplicationAuditLog {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actorUserId   String?
  actor         User?       @relation("AuditLogActor", fields: [actorUserId], references: [id])

  // CLAIM | RELEASE | FILL_PACKAGE_ISSUED | OPERATOR_SUBMITTED | OPERATOR_FAILED | PLAYWRIGHT_RESULT
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([applicationId])
  @@index([actorUserId])
}
